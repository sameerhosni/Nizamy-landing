# PostHog analytics (Vite inlines VITE_* vars at build time).
# Copy this file to `.env` and fill in real values, or set these as build-time
# environment variables (e.g. Replit Secrets) so Vite picks them up during the
# production build.
VITE_POSTHOG_KEY=your_posthog_project_api_token
VITE_POSTHOG_HOST=https://us.i.posthog.com
